# Supabase
# Using the new (2024+) Supabase key format: publishable + secret.
# Find both at: Dashboard → Settings → API → "API keys"
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Direct Postgres connection (for Drizzle migrations + server-side direct queries)
# In Supabase dashboard: Settings → Database → Connection string → URI (use the
# "Transaction" pooler for serverless, or "Direct connection" for migrations).
DATABASE_URL=postgresql://postgres.<ref>:<password>@<host>:5432/postgres

# AI providers (used in Plan 4; safe to leave blank for now)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# External data sources
# IUCN_API_TOKEN deferred to Plan 2.5 (commercial-use license required)
GFW_API_KEY=           # generate at globalforestwatch.org → My Account → API Keys

# Vercel Cron auth (for /api/etl/* routes; same value in Vercel project env vars)
CRON_SECRET=

# Email (used in Plan 7; safe to leave blank for now)
RESEND_API_KEY=
